{
  "name": "sth-app-template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode dev",
    "build:prod": "vite build --mode prod",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:visual": "playwright test tests/e2e/visual.spec.ts",
    "test:e2e:buttons": "playwright test tests/e2e/button-contract.spec.ts tests/e2e/screenshot.spec.ts",
    "test:e2e:core": "playwright test tests/e2e/incident-form.spec.ts",
    "test:e2e:incident:api-guard": "playwright test tests/e2e/incident-employee-persistence-api.spec.ts",
    "test:e2e:audit:core": "playwright test tests/e2e/audit-new-audit.spec.ts tests/e2e/audit-navigation-stability.spec.ts",
    "test:e2e:audit:corrective-actions": "playwright test tests/e2e/audit-corrective-actions-contract.spec.ts",
    "test:e2e:audit:visual": "playwright test tests/e2e/audit-visual.spec.ts tests/e2e/audit-visual-all-pages.spec.ts",
    "test:e2e:audit:visual:all": "playwright test tests/e2e/audit-visual.spec.ts tests/e2e/audit-visual-all-pages.spec.ts",
    "test:e2e:audit:parity": "playwright test tests/e2e/audit-parity.spec.ts",
    "test:e2e:audit:phase2c": "playwright test tests/e2e/audit-review-distribution-contract.spec.ts tests/e2e/audit-review-assign-ca-sla-contract.spec.ts tests/e2e/audit-corrective-actions-contract.spec.ts tests/e2e/admin-users-contract.spec.ts",
    "test:e2e:audit:live-guard": "playwright test tests/e2e/audit-live-api-guard.spec.ts tests/e2e/audit-live-blank-screen-guard.spec.ts tests/e2e/audit-live-dashboard-api-contract.spec.ts tests/e2e/audit-live-navigation-stress.spec.ts",
    "test:e2e:audit:template-gate": "playwright test tests/e2e/audit-template-admin-contract.spec.ts",
    "test:e2e:audit:composer-gate": "playwright test tests/e2e/audit-report-composer-contract.spec.ts",
    "test:e2e:audit:reporting-gate": "playwright test tests/e2e/audit-newsletter.spec.ts tests/e2e/audit-report-composer-contract.spec.ts tests/e2e/audit-kpi-reporting-contract.spec.ts",
    "test:e2e:live": "playwright test tests/e2e/live-db-logging.spec.ts",
    "test:e2e:full": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "qa:baseline": "npm run build && npm run test:e2e:audit:live-guard && npm run test:e2e:smoke && npm run test:e2e:visual && npm run test:e2e:audit:visual:all && npm run test:e2e:buttons && npm run test:e2e:core && npm run test:e2e:incident:api-guard && npm run test:e2e:audit:core && npm run test:e2e:audit:corrective-actions",
    "qa:full": "npm run test:e2e:full && npm run test:e2e:live",
    "qa:pr": "npm run qa:full",
    "qa:premerge": "npm run qa:full",
    "qa:prerelease": "npm run qa:full"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.20.0",
    "@microsoft/signalr": "^8.0.7",
    "@tiptap/extension-bullet-list": "^3.22.3",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-font-family": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-list-item": "^3.22.3",
    "@tiptap/extension-ordered-list": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "axios": "^1.7.2",
    "chart.js": "3.3.2",
    "nprogress": "^0.2.0",
    "pinia": "^2.2.0",
    "primeflex": "^3.3.0",
    "primeicons": "^6.0.1",
    "primevue": "3.26.1",
    "tailwindcss": "^3.4.1",
    "vite-plugin-mkcert": "^1.17.5",
    "vue": "^3.2.45",
    "vue-router": "^4.1.6",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rushstack/eslint-patch": "^1.1.4",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-prettier": "^7.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.21.1",
    "lint-staged": "^15.5.2",
    "prettier": "^2.8.8",
    "typescript": "^5.5.4",
    "unplugin-vue-components": "^0.27.5",
    "vite": "^6.2.5"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{css,scss,html}": [
      "prettier --write"
    ]
  }
}
